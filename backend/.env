# Local development
NODE_ENV=development
PORT=8080
CORS_ORIGIN=http://localhost:2000
LOG_LEVEL=http
HASH_SALT=dev-only-change-me

# Optional: enable Grok-powered AI mentor (LangChain)
# GROK_API_KEY=
GROK_BASE_URL=https://api.x.ai/v1
GROK_MODEL=grok-2-latest

# MongoDB
# Local MongoDB (recommended for dev)
MONGODB_URI=mongodb+srv://Priyanshu:hello9090@cluster0.3qui3hc.mongodb.net/?appName=Cluster0

# If you want to use MongoDB Atlas instead, replace MONGODB_URI with your Atlas URI.
# Tip: ensure the DB user/password are correct and your IP is allowed in Atlas Network Access.
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/<db>?retryWrites=true&w=majority

# Auth (JWT)
JWT_SECRET=dev-only-change-me-please
JWT_EXPIRES_IN=7d
